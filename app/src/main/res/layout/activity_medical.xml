<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F172A"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:background="@drawable/bg_circle_dark"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFFFFF"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical Info"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shared during emergencies"
                android:textColor="#94A3B8"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_below="@id/header"
        android:layout_above="@id/footer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CARD 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Critical Information"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Blood Group -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Blood Group"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spBlood"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:entries="@array/blood_group" />

                    <!-- Weight -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Weight (kg)"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:hint="Enter weight"
                        android:inputType="number"
                        android:paddingHorizontal="16dp" />

                    <!-- Allergies -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Known Allergies"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etAllergy"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:gravity="top"
                        android:hint="e.g. Pollen, (none)"
                        android:padding="14dp" />

                    <!-- Conditions -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Chronic Conditions"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etCondition"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:gravity="top"
                        android:hint="e.g. Heart Disease, (none)"
                        android:padding="14dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:padding="18dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medical History"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Medication -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Medications"
                        android:textSize="13sp"
                        android:textColor="#64748B"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etMedication"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:gravity="top"
                        android:hint="List medications you take regularly"
                        android:padding="14dp"/>

                    <!-- Surgery -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Past Surgeries"
                        android:textSize="13sp"
                        android:textColor="#64748B"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                    <EditText
                        android:id="@+id/etSurgery"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:gravity="top"
                        android:hint="e.g. Heart Surgery -2019, (none)"
                        android:padding="14dp"/>

                    <!-- Doctor -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doctor Contact"
                        android:textSize="13sp"
                        android:textColor="#64748B"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                    <EditText
                        android:id="@+id/etDoctor"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edittext_rounded_bg"
                        android:inputType="phone"
                        android:hint="+91XXXXXXXXXX"
                        android:paddingHorizontal="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BUTTON -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#FFFFFF">

        <Button
            android:id="@+id/btnSaveMedical"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SAVE MEDICAL INFO"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F172A"/>
    </LinearLayout>

</RelativeLayout>